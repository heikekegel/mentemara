<div style="font-family: Arial, sans-serif; max-width: 1000px; margin: 60px auto;">
  <h1 style="font-size: 36px; margin-bottom: 10px;">Submitted Intakes</h1>
  <p style="color: #555; margin-bottom: 30px;">
    Review all behavioral health intake submissions.
  </p>

  <% if @intakes.any? %>
    <table style="width: 100%; border-collapse: collapse; background: white;">
      <thead>
        <tr style="background: #f2f2f2;">
          <th style="text-align: left; padding: 12px; border: 1px solid #ddd;">Name</th>
          <th style="text-align: left; padding: 12px; border: 1px solid #ddd;">Email</th>
          <th style="text-align: left; padding: 12px; border: 1px solid #ddd;">Phone</th>
          <th style="text-align: left; padding: 12px; border: 1px solid #ddd;">Urgency</th>
          <th style="text-align: left; padding: 12px; border: 1px solid #ddd;">Reason for Visit</th>
          <th style="text-align: left; padding: 12px; border: 1px solid #ddd;">Submitted At</th>
          <th style="padding: 12px; border: 1px solid #ddd;">Actions</th>  
        </tr>
      </thead>
      <tbody>
        <% @intakes.each do |intake| %>
          <tr id="intake-<%= intake.id %>">
            <td style="padding: 12px; border: 1px solid #ddd;"><%= link_to intake.full_name, intake_path(intake) %></td>
            <td style="padding: 12px; border: 1px solid #ddd;"><%= intake.email %></td>
            <td style="padding: 12px; border: 1px solid #ddd;"><%= intake.phone %></td>
            <td style="padding: 12px; border: 1px solid #ddd;"><%= intake.urgency %></td>
            <td style="padding: 12px; border: 1px solid #ddd;"><%= intake.reason_for_visit %></td>
            <td style="padding: 12px; border: 1px solid #ddd;"><%= intake.created_at.strftime("%Y-%m-%d %H:%M") %></td>        
            <td style="padding: 12px; border: 1px solid #ddd;">

              <%= link_to "Edit", edit_intake_path(intake), style: "
                display: inline-block;
                padding: 6px 12px;
                background-color: blue;
                color: white;
                border-radius: 4px;
                text-decoration: none;
                font-size: 14px;
                margin-bottom: 4px;
              " %>

              <a href="#" onclick="deleteIntake(<%= intake.id %>); return false;"
                style="
                  display: inline-block;
                  padding: 6px 12px;
                  background-color: #e74c3c;
                  color: white;
                  border-radius: 4px;
                  text-decoration: none;
                  font-size: 14px;
                ">
                Delete
              </a>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No intake submissions yet.</p>
  <% end %>

  <div style="margin-top: 30px;">
    <%= link_to "Return Home", "/", style: "
      display: inline-block;
      padding: 12px 24px;
      font-size: 16px;
      background-color: #2d7ff9;
      color: white;
      border-radius: 6px;
      text-decoration: none;
    " %>
  </div>
</div>
